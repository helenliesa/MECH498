  PluginText: "<macro name=\"common_link_visual\" params=\"mesh_filename origin_xyz
    origin_rpy material_name\">\r\n  <visual>\r\n    <origin xyz=\"${origin_xyz}\"
    rpy=\"${origin_rpy}\" />\r\n    <geometry>\r\n      <mesh filename=\"package://xarm_description/meshes/${mesh_filename}.stl\"
    />\r\n    </geometry>\r\n    <material name=\"${material_name}\" />\r\n  </visual>\r\n</macro>"
