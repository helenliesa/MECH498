  m_Name: 
  m_EditorClassIdentifier: 
  PluginText: "<macro name=\"common_link_collision\" params=\"mesh_filename origin_xyz
    origin_rpy\">\r\n  <collision>\r\n    <origin xyz=\"${origin_xyz}\" rpy=\"${origin_rpy}\"
    />\r\n    <geometry>\r\n      <mesh filename=\"package://xarm_description/meshes/${mesh_filename}.stl\"
    />\r\n    </geometry>\r\n  </collision>\r\n</macro>"
