    ${link_inertial_params['y']} ${link_inertial_params['z']}\" rpy=\"${origin_rpy}\"
    />\r\n    <mass value=\"${link_inertial_params['mass']}\" />\r\n    <inertia
    ixx=\"${link_inertial_params['ixx']}\" ixy=\"${link_inertial_params['ixy']}\"
    ixz=\"${link_inertial_params['ixz']}\" iyy=\"${link_inertial_params['iyy']}\"
    iyz=\"${link_inertial_params['iyz']}\" izz=\"${link_inertial_params['izz']}\"
    />\r\n  </inertial>\r\n</macro>"
